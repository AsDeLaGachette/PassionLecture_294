meta {
  name: Create Review
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/books/{{bookId}}/reviews
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "Kewl",
    "rating": 5,
    "comment": "Un livre magnifique, à lire absolument !",
    "userId": 1,
    ""
  }
}
