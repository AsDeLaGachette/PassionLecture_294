meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/user/login
  body: json
  auth: none
}

body:json {
  {
    "email": "john@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.getStatus() >= 200 && res.getStatus() < 300) {
    const body = res.getBody();
    if (body && body.token) {
      bru.setEnvVar("token", body.token.token || body.token);
    }
  }
}
