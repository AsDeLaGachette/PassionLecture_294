meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/user/register
  body: json
  auth: none
}

body:json {
  {
    "fullName": "John Doe",
    "email": "john@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.getStatus() >= 200 && res.getStatus() < 300) {
    const body = res.getBody();
    if (body && body.token) {
      bru.setEnvVar("token", body.token.token || body.token);
    }
  }
}
